# Core app
NODE_ENV=production
MAFITAPAY_APP_URL=https://app.example.com
MAFITAPAY_ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_MAFITAPAY_ADMIN_EMAIL=admin@example.com

# Security
MAFITAPAY_SENSITIVE_DATA_KEY=replace-with-32-byte-secret
MAFITAPAY_WEBHOOK_SECRET=replace-with-random-webhook-secret
MAFITAPAY_JOB_SECRET=replace-with-random-job-secret

# WebAuthn / biometric approval
MAFITAPAY_WEBAUTHN_RP_ID=app.example.com
MAFITAPAY_WEBAUTHN_RP_NAME=MafitaPay

# Auth delivery: email
MAFITAPAY_RESEND_API_KEY=
MAFITAPAY_RESEND_FROM_EMAIL=no-reply@example.com
MAFITAPAY_RESEND_FROM_NAME=MafitaPay

# Auth delivery: SMS
MAFITAPAY_TERMII_API_KEY=
MAFITAPAY_TERMII_SENDER_ID=MafitaPay
MAFITAPAY_TERMII_CHANNEL=generic

# Bank resolution
MAFITAPAY_BANK_RESOLUTION_PROVIDER=flutterwave

# PalmPay virtual accounts
MAFITAPAY_PALMPAY_BASE_URL=
MAFITAPAY_PALMPAY_APP_ID=
MAFITAPAY_PALMPAY_AUTH_TOKEN=
MAFITAPAY_PALMPAY_MERCHANT_PRIVATE_KEY=
MAFITAPAY_PALMPAY_PUBLIC_KEY=
MAFITAPAY_PALMPAY_COUNTRY_CODE=NG

# Flutterwave: shared
MAFITAPAY_FLUTTERWAVE_BASE_URL=
MAFITAPAY_FLUTTERWAVE_SECRET_KEY=
MAFITAPAY_FLUTTERWAVE_SECRET_HASH=

# Flutterwave: collections / payouts / callbacks
MAFITAPAY_FLUTTERWAVE_CLIENT_ID=
MAFITAPAY_FLUTTERWAVE_CLIENT_SECRET=
MAFITAPAY_FLUTTERWAVE_TOKEN_URL=
MAFITAPAY_FLUTTERWAVE_CALLBACK_URL=https://app.example.com/api/webhooks/flutterwave
MAFITAPAY_FLUTTERWAVE_BILLS_CALLBACK_URL=https://app.example.com/api/webhooks/flutterwave
MAFITAPAY_FLUTTERWAVE_TRANSFERS_BASE_URL=

# Bills provider: Amigo
MAFITAPAY_AMIGO_BASE_URL=https://amigo.ng/api
MAFITAPAY_AMIGO_API_KEY=

# Crypto market
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
MAFITAPAY_DEBUG_CRYPTO_MARKET=0
MAFITAPAY_DEBUG_CRYPTO=1

# LI.FI
MAFITAPAY_LIFI_BASE_URL=https://li.quest/v1
MAFITAPAY_LIFI_API_KEY=

# 0x / Base treasury
MAFITAPAY_ZEROX_API_KEY=
MAFITAPAY_ZEROX_BASE_URL=
MAFITAPAY_BASE_RPC_URL=
MAFITAPAY_BASE_RPC_URLS=
MAFITAPAY_BASE_EXECUTOR_PRIVATE_KEY=
MAFITAPAY_BASE_EXECUTOR_ADDRESS=
MAFITAPAY_BASE_RESERVE_ADDRESS=
MAFITAPAY_BASE_USDC_ADDRESS=
MAFITAPAY_BASE_WETH_ADDRESS=

# BSC treasury
MAFITAPAY_BSC_RPC_URL=
MAFITAPAY_BSC_RPC_URLS=
MAFITAPAY_BSC_EXECUTOR_PRIVATE_KEY=
MAFITAPAY_BSC_EXECUTOR_ADDRESS=
MAFITAPAY_BSC_USDT_ADDRESS=

# Sui treasury
MAFITAPAY_SUI_RPC_URL=
MAFITAPAY_SUI_RPC_URLS=
MAFITAPAY_SUI_TREASURY_PRIVATE_KEY=
MAFITAPAY_SUI_TREASURY_ADDRESS=
MAFITAPAY_SUI_ROUTER_BASE_URL=
MAFITAPAY_SUI_USDC_COIN_TYPE=
MAFITAPAY_SUI_NATIVE_COIN_TYPE=
MAFITAPAY_SUI_SWAP_SLIPPAGE_BPS=

# NEAR intents / treasury
MAFITAPAY_NEAR_INTENTS_BASE_URL=
MAFITAPAY_NEAR_INTENTS_JWT=
MAFITAPAY_NEAR_RPC_URL=
MAFITAPAY_NEAR_RPC_URLS=
MAFITAPAY_NEAR_TREASURY_ACCOUNT_ID=
MAFITAPAY_NEAR_TREASURY_PRIVATE_KEY=
MAFITAPAY_NEAR_BASE_USDC_ASSET_ID=
MAFITAPAY_NEAR_DESTINATION_ASSET_ID=
MAFITAPAY_NEAR_SLIPPAGE_BPS=

# TON executor
MAFITAPAY_TON_RPC_URL=
MAFITAPAY_TON_API_KEY=
MAFITAPAY_TON_EXECUTOR_MNEMONIC=
MAFITAPAY_TON_EXECUTOR_ADDRESS=
MAFITAPAY_TON_USDT_MASTER_ADDRESS=

# Logging / diagnostics
MAFITAPAY_DEBUG_BILLS=0
MAFITAPAY_DEBUG_PALMPAY=0

# Polygon (for POL deposit scanning + sweeps). Public endpoints often 401/"tenant disabled".
# Put the most reliable first. Consider a dedicated key.
MAFITAPAY_POLYGON_RPC_URL=https://rpc.ankr.com/polygon
MAFITAPAY_POLYGON_RPC_URLS=https://rpc.ankr.com/polygon,https://polygon.llamarpc.com
MAFITAPAY_POLYGON_EXECUTOR_PRIVATE_KEY=
MAFITAPAY_POLYGON_EXECUTOR_ADDRESS=
